# Copy to .env and fill in secrets (never commit .env)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=copilotx

REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

RAG_TOP_K=3
RAG_MIN_SIMILARITY=0.25

LOG_LEVEL=INFO
LOG_FORMAT=text
DEBUG=false

# HTTP: mount routes under prefix (e.g. /api/v1) for API gateway
API_PREFIX=

# Domain events: noop | log (structured stdout; swap for Kafka/Redis in app.main lifespan)
EVENT_SINK=noop
